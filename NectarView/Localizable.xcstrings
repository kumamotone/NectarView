    "You don't have permission to access this file. Please check the application's permission settings.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You don't have permission to access this file. Please check the application's permission settings."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ファイルへのアクセス権限がありません。アプリケーションの権限設定を確認してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您没有访问此文件的权限。请检查应用程序的权限设置。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "您沒有存取此檔案的權限。請檢查應用程式的權限設定。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 파일에 액세스할 권한이 없습니다. 애플리케이션의 권한 설정을 확인하세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous n'avez pas la permission d'accéder à ce fichier. Veuillez vérifier les paramètres d'autorisation de l'application."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie haben keine Berechtigung, auf diese Datei zuzugreifen. Bitte überprüfen Sie die Berechtigungseinstellungen der Anwendung."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No tiene permiso para acceder a este archivo. Por favor, verifique la configuración de permisos de la aplicación."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Você não tem permissão para acessar este arquivo. Por favor, verifique as configurações de permissão do aplicativo."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "คุณไม่มีสิทธิ์เข้าถึงไฟล์นี้ กรุณาตรวจสอบการตั้งค่าสิทธิ์ของแอปพลิเคชัน"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Bạn không có quyền truy cập tệp này. Vui lòng kiểm tra cài đặt quyền của ứng dụng."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Anda tidak memiliki izin untuk mengakses file ini. Silakan periksa pengaturan izin aplikasi."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Non hai il permesso di accedere a questo file. Controlla le impostazioni dei permessi dell'applicazione."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Nie masz uprawnień do dostępu do tego pliku. Sprawdź ustawienia uprawnień aplikacji."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bu dosyaya erişim izniniz yok. Lütfen uygulamanın izin ayarlarını kontrol edin."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "У вас нет прав доступа к этому файлу. Пожалуйста, проверьте настройки разрешений приложения."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Anda tidak mempunyai kebenaran untuk mengakses fail ini. Sila semak tetapan kebenaran aplikasi."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "U heeft geen toestemming om dit bestand te openen. Controleer de machtigingsinstellingen van de applicatie."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "Du har inte behörighet att komma åt den här filen. Kontrollera programmets behörighetsinställningar."
