    "You don't have permission to access this file. Please check the application's permission settings.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "You don't have permission to access this file. Please check the application's permission settings."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "ファイルへのアクセス権限がありません。アプリケーションの権限設定を確認してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "您没有访问此文件的权限。请检查应用程序的权限设置。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "您沒有存取此檔案的權限。請檢查應用程式的權限設定。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 파일에 액세스할 권한이 없습니다. 애플리케이션의 권한 설정을 확인하세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Vous n'avez pas la permission d'accéder à ce fichier. Veuillez vérifier les paramètres d'autorisation de l'application."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Sie haben keine Berechtigung, auf diese Datei zuzugreifen. Bitte überprüfen Sie die Berechtigungseinstellungen der Anwendung."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "No tiene permiso para acceder a este archivo. Por favor, verifique la configuración de permisos de la aplicación."
          }
        }
      }
    },
    "Zoom and Rotate": {
