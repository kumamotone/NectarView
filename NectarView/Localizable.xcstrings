    "TipJar.Description" : {
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NectarView er gratis og open source.\nHvis du kan lide det, hjælper en lille drikkepenge med at fortsætte udviklingen!"
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NectarView ist kostenlos und Open Source.\nWenn es Ihnen gefällt, hilft ein kleines Trinkgeld bei der Weiterentwicklung!"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NectarView is free and open source.\nIf you enjoy using it, a small tip helps keep development going!"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NectarView es gratuito y de código abierto.\nSi le gusta, una pequeña propina ayuda a continuar el desarrollo."
          }
        },
        "fi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NectarView on ilmainen ja avoimen lähdekoodin ohjelmisto.\nJos pidät siitä, pieni tippi auttaa kehityksen jatkumista!"
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NectarView est gratuit et open source.\nSi vous l'appréciez, un petit pourboire aide à poursuivre le développement !"
          }
        },
        "id" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NectarView adalah perangkat lunak gratis dan open source.\nJika Anda menikmatinya, tip kecil membantu pengembangan berlanjut!"
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NectarView è gratuito e open source.\nSe ti piace usarlo, una piccola mancia aiuta a continuare lo sviluppo!"
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NectarViewは無料のオープンソースソフトウェアです。\n気に入っていただけたら、チップで開発を応援してください！"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NectarView는 무료 오픈소스 소프트웨어입니다.\n유용하게 사용하셨다면 작은 팁으로 개발을 응원해주세요!"
          }
        },
        "ms" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NectarView adalah perisian percuma dan sumber terbuka.\nJika anda menikmatinya, tip kecil membantu pembangunan berterusan!"
          }
        },
        "nb" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NectarView er gratis og åpen kildekode.\nHvis du liker det, hjelper et lite tips med å fortsette utviklingen!"
          }
        },
        "nl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NectarView is gratis en open source.\nAls je het leuk vindt, helpt een kleine fooi om de ontwikkeling voort te zetten!"
          }
        },
        "pl" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NectarView jest darmowy i open source.\nJeśli Ci się podoba, mały napiwek pomoże w dalszym rozwoju!"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NectarView é gratuito e de código aberto.\nSe você gosta de usá-lo, uma pequena gorjeta ajuda a manter o desenvolvimento!"
          }
        },
        "ru" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NectarView — бесплатное ПО с открытым исходным кодом.\nЕсли вам нравится, небольшие чаевые помогут продолжить разработку!"
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NectarView är gratis och öppen källkod.\nOm du gillar det, hjälper en liten dricks till att fortsätta utvecklingen!"
          }
        },
        "th" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NectarView เป็นซอฟต์แวร์ฟรีและโอเพนซอร์ส\nหากคุณชอบใช้งาน ทิปเล็กๆ น้อยๆ จะช่วยสนับสนุนการพัฒนาต่อไป!"
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NectarView ücretsiz ve açık kaynaklıdır.\nBeğendiyseniz, küçük bir bahşiş geliştirmeye devam etmeye yardımcı olur!"
          }
        },
        "vi" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NectarView là phần mềm miễn phí và mã nguồn mở.\nNếu bạn thích sử dụng, một khoản tip nhỏ sẽ giúp duy trì phát triển!"
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NectarView 是免费开源软件。\n如果您喜欢使用它，一点小小的打赏将帮助持续开发！"
          }
        },
        "zh-Hant" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "NectarView 是免費開源軟體。\n如果您喜歡使用它，一點小小的打賞將幫助持續開發！"
          }
        }
      }
