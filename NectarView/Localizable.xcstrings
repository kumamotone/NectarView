    "You don't have permission to access this file. Please check the application's permission settings." : {
      "localizations" : {
        "da" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Du har ikke tilladelse til at få adgang til denne fil. Kontroller programmets tilladelsesindstillinger."
          }
        },
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Sie haben keine Berechtigung, auf diese Datei zuzugreifen. Bitte überprüfen Sie die Berechtigungseinstellungen der Anwendung."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "You don't have permission to access this file. Please check the application's permission settings."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No tiene permiso para acceder a este archivo. Por favor, verifique la configuración de permisos de la aplicación."
