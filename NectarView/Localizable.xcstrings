    "Please restart the application for the language change to take effect.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Please restart the application for the language change to take effect."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "言語の変更を反映するには、アプリケーションを再起動してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "请重启应用程序以使语言更改生效。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "請重新啟動應用程式以使語言變更生效。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "언어 변경 사항을 적용하려면 애플리케이션을 다시 시작하세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Veuillez redémarrer l'application pour que le changement de langue prenne effet."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Bitte starten Sie die Anwendung neu, damit die Sprachänderung wirksam wird."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Por favor, reinicie la aplicación para que el cambio de idioma surta efecto."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Por favor, reinicie o aplicativo para que a alteração de idioma entre em vigor."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "กรุณาเริ่มต้นแอปพลิเคชันใหม่เพื่อให้การเปลี่ยนภาษามีผล"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Vui lòng khởi động lại ứng dụng để thay đổi ngôn ngữ có hiệu lực."
          }
        },
        "id": {
