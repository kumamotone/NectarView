    "Enable auto page turn in the settings menu. Adjust the interval to set how quickly pages turn automatically.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Enable auto page turn in the settings menu. Adjust the interval to set how quickly pages turn automatically."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "設定メニューで自動ページめくりを有効にします。間隔を調整して、ページが自動的にめくられる速さを設定します。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "在设置菜单中启用自动翻页。调整间隔以设置自动翻页的速度。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "在設定選單中啟用自動翻頁。調整間隔以設定自動翻頁的速度。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "설정 메뉴에서 자동 페이지 넘기기를 활성화하세요. 간격을 조정하여 자동으로 페이지가 넘어가는 속도를 설정합니다."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Activez le tournage automatique de page dans le menu des réglages. Ajustez l'intervalle pour définir la vitesse de défilement automatique."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Aktivieren Sie das automatische Blättern im Einstellungsmenü. Passen Sie das Intervall an, um die Geschwindigkeit des automatischen Blätterns festzulegen."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Active el paso de página automático en el menú de configuración. Ajuste el intervalo para establecer la velocidad del paso de página automático."
          }
        }
      }
    },
