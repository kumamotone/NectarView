    "PasswordRequiredMessage": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "This archive is password protected. Please enter the password."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "このアーカイブはパスワードで保護されています。パスワードを入力してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "此压缩包受密码保护。请输入密码。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "此壓縮檔受密碼保護。請輸入密碼。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "이 아카이브는 비밀번호로 보호되어 있습니다. 비밀번호를 입력하세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Cette archive est protégée par un mot de passe. Veuillez entrer le mot de passe."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Dieses Archiv ist passwortgeschützt. Bitte geben Sie das Passwort ein."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Este archivo está protegido con contraseña. Por favor, ingrese la contraseña."
          }
        }
      }
    },
