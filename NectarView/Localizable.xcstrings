    "PleaseCheckPermissionDialog": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A permission dialog has been displayed. Please check your screen and grant access to continue."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "アクセス許可のダイアログが表示されています。画面を確認して、アクセスを許可してください。"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "已显示权限对话框。请检查您的屏幕并授予访问权限以继续。"
          }
        },
        "zh-Hant": {
          "stringUnit": {
            "state": "translated",
            "value": "已顯示權限對話框。請檢查您的螢幕並授予存取權限以繼續。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "권한 대화 상자가 표시되었습니다. 화면을 확인하고 계속하려면 액세스 권한을 부여하세요."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Une boîte de dialogue d'autorisation a été affichée. Veuillez vérifier votre écran et accorder l'accès pour continuer."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein Berechtigungsdialog wurde angezeigt. Bitte überprüfen Sie Ihren Bildschirm und erteilen Sie den Zugriff, um fortzufahren."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Se ha mostrado un diálogo de permisos. Por favor, revise su pantalla y otorgue acceso para continuar."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Uma caixa de diálogo de permissão foi exibida. Por favor, verifique sua tela e conceda acesso para continuar."
          }
        },
        "th": {
          "stringUnit": {
            "state": "translated",
            "value": "กล่องโต้ตอบสิทธิ์ถูกแสดงขึ้น กรุณาตรวจสอบหน้าจอของคุณและให้สิทธิ์การเข้าถึงเพื่อดำเนินการต่อ"
          }
        },
        "vi": {
          "stringUnit": {
            "state": "translated",
            "value": "Hộp thoại cấp quyền đã được hiển thị. Vui lòng kiểm tra màn hình của bạn và cấp quyền truy cập để tiếp tục."
          }
        },
        "id": {
          "stringUnit": {
            "state": "translated",
            "value": "Dialog izin telah ditampilkan. Silakan periksa layar Anda dan berikan akses untuk melanjutkan."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "È stata visualizzata una finestra di dialogo per i permessi. Controlla lo schermo e concedi l'accesso per continuare."
          }
        },
        "pl": {
          "stringUnit": {
            "state": "translated",
            "value": "Wyświetlono okno dialogowe uprawnień. Sprawdź ekran i przyznaj dostęp, aby kontynuować."
          }
        },
        "tr": {
          "stringUnit": {
            "state": "translated",
            "value": "Bir izin iletişim kutusu görüntülendi. Lütfen ekranınızı kontrol edin ve devam etmek için erişime izin verin."
          }
        },
        "ru": {
          "stringUnit": {
            "state": "translated",
            "value": "Отображено диалоговое окно разрешений. Пожалуйста, проверьте экран и предоставьте доступ для продолжения."
          }
        },
        "ms": {
          "stringUnit": {
            "state": "translated",
            "value": "Dialog kebenaran telah dipaparkan. Sila semak skrin anda dan berikan akses untuk meneruskan."
          }
        },
        "nl": {
          "stringUnit": {
            "state": "translated",
            "value": "Er is een toestemmingsvenster weergegeven. Controleer uw scherm en verleen toegang om door te gaan."
          }
        },
        "sv": {
          "stringUnit": {
            "state": "translated",
            "value": "En behörighetsdialog har visats. Kontrollera din skärm och bevilja åtkomst för att fortsätta."
          }
        },
        "da": {
          "stringUnit": {
            "state": "translated",
            "value": "En tilladelsesdialog er blevet vist. Kontroller din skærm og giv adgang for at fortsætte."
          }
        },
        "nb": {
          "stringUnit": {
            "state": "translated",
            "value": "En tillatelsesdialog har blitt vist. Kontroller skjermen og gi tilgang for å fortsette."
          }
        },
        "fi": {
          "stringUnit": {
            "state": "translated",
            "value": "Lupavalikko on näytetty. Tarkista näyttösi ja myönnä pääsy jatkaaksesi."
          }
        }
      }
    },
